{
  "permissions": {
    "defaultMode": "plan",
    "deny": [
      "Read(.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "allow": [
      "WebSearch",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(rg:*)"
    ]
  },
  "model": "claude-opus-4-8",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}